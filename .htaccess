# ─── PHP Upload limits ────────────────────────────────────────────────────────
<IfModule mod_php.c>
    php_value upload_max_filesize 200M
    php_value post_max_size 200M
    php_value memory_limit 512M
    php_value max_execution_time 300
</IfModule>
<IfModule mod_php8.c>
    php_value upload_max_filesize 200M
    php_value post_max_size 200M
    php_value memory_limit 512M
    php_value max_execution_time 300
</IfModule>

# ─── Security Headers ─────────────────────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ─── Bloquer les fichiers sensibles de debug/migration ────────────────────────
<FilesMatch "^(session_test|migrate_auth|migrate_db_signalement|migrate_signalement|init_db|init_education|init_opendata|init_signalement|migration_auth)\.php$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# ─── Protéger les fichiers de config ─────────────────────────────────────────
<FilesMatch "\.(sql|ini|log|env)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# ─── Empêcher la navigation dans les répertoires ──────────────────────────────
Options -Indexes

